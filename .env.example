# Bridge — Multi-tenant Payment Sync for Stripe
#
# STRIPE_SECRET_KEY is now OPTIONAL. Merchants provide their own keys
# via OAuth or the setup wizard after registration.
STRIPE_SECRET_KEY=

# Stripe OAuth Client ID (required for "Connect with Stripe" button)
# Found at: Stripe Dashboard → Settings → Connect → Onboarding
STRIPE_CLIENT_ID=

# PayPal (optional — used as default fallback if merchants don't configure)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# Stripe Billing — required for subscriptions
# Get publishable key from Stripe Dashboard → Developers → API keys
STRIPE_PUBLISHABLE_KEY=

# Stripe Price ID — create a product in Stripe Dashboard → Products with a $49/mo recurring price
STRIPE_PRICE_ID=

# Paddle Billing — for subscriptions
# Get from Paddle Dashboard → Developer Tools → Authentication
PADDLE_API_KEY=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=

# Sentry — error tracking (optional but recommended)
SENTRY_DSN=

# Encryption — AES-256 key for credential storage at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# App URL — used for Stripe OAuth redirects, links, and CORS.
# Set to your production URL (e.g. https://bridge.onrender.com).
# Default: http://localhost:3000
BASE_URL=

# Master API key (optional — grants admin access to all merchant data)
MASTER_API_KEY=

# PostgreSQL (required!)
DATABASE_URL=

# App
PORT=3000
