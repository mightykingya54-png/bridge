# Bridge — Multi-tenant Payment Sync for Stripe
#
# STRIPE_SECRET_KEY is now OPTIONAL. Merchants provide their own keys
# via OAuth or the setup wizard after registration.
STRIPE_SECRET_KEY=

# Stripe OAuth Client ID (required for "Connect with Stripe" button)
# Found at: Stripe Dashboard → Settings → Connect → Onboarding
STRIPE_CLIENT_ID=

# PayPal (optional — used as default fallback if merchants don't configure)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# Master API key (optional — grants admin access to all merchant data)
MASTER_API_KEY=

# PostgreSQL (required!)
# Railway sets this automatically when you add PostgreSQL plugin.
# For local dev, use your own Postgres URL.
DATABASE_URL=

# App
PORT=3000
